{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",

    "moduleResolution": "Bundler",

    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["./dist", "./node_modules"]
}

